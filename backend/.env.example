DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/elite
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/elite_test
LOG_DIR=data/logs
ENVIRONMENT=development
FLIGHT_CONTROL_MAX_SPEED_UNITS=12.0
FLIGHT_CONTROL_FORWARD_ACCELERATION=7.5
FLIGHT_CONTROL_REVERSE_ACCELERATION=6.0
FLIGHT_CONTROL_YAW_RATE_DEG_PER_SEC=91.67324722093171
FLIGHT_CONTROL_PITCH_RATE_DEG_PER_SEC=68.75493541569878
FLIGHT_CONTROL_ROLL_RATE_DEG_PER_SEC=91.67324722093171
FLIGHT_CONTROL_INPUT_TIMEOUT_SECONDS=1.6
FLIGHT_CONTROL_SIMULATION_MAX_STEP_SECONDS=5.0
FLIGHT_CONTROL_ACTIVE_POLL_INTERVAL_MS=450
FLIGHT_COLLISION_ENABLED=true
DOCK_APPROACH_ENABLED=true
FLIGHT_COLLISION_COOLDOWN_SECONDS=2
FLIGHT_COLLISION_RADIUS_SCALE=1.0
FLIGHT_COLLISION_DAMAGE_SCALE=1.0
FLIGHT_COLLISION_GLANCING_MULTIPLIER=1.08
FLIGHT_COLLISION_CRITICAL_MULTIPLIER=0.58
